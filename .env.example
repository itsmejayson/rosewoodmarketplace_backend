# Server
NODE_ENV=development
PORT=5000

# Database - Neon PostgreSQL
DATABASE_URL="postgresql://username:password@ep-xxxx.us-east-1.aws.neon.tech/rosewood_marketplace?sslmode=require"

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary (for image uploads - products, profile pics, GCash receipts)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# GCash (displayed on payment instructions)
GCASH_MERCHANT_NUMBER=09XX-XXX-XXXX
GCASH_MERCHANT_NAME=Rosewood Marketplace

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Anthropic (AI chat assistant)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
